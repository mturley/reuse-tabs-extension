{
  "manifest_version": 2,
  "name": "Reuse Tabs",
  "version": "1.0.0",
  "description": "When navigating to a URL that's already open in another tab, switch to that tab instead.",
  "permissions": [
    "tabs",
    "menus",
    "notifications",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Reuse Tabs"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "reuse-tabs@mturley"
    }
  }
}
